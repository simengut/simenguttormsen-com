---
import Site from '../layouts/Site.astro';
import { papers } from '../data/papers';
---
<Site title="Research" page="research"
  description="Research papers and projects by Simen Guttormsen — implied volatility, volatility spillovers, event risk.">

<section class="page-header container">
  <h1>Research</h1>
  <p class="lede">Implied-volatility surfaces, volatility spillovers, and how investors learn about event risk.</p>
</section>

<section class="container content-section">
  <h2>Selected publications</h2>

  {papers.map((paper) => (
    <article class="paper">
      <h3>{paper.title}</h3>
      <p class="paper-meta">
        {paper.authorship} &middot; <Fragment set:html={paper.status} />
      </p>
      <p class="paper-abstract" set:html={paper.abstract}></p>
      <p class="paper-links">
        {paper.pdf && <a href={paper.pdf}>PDF</a>}
        {paper.pdf && paper.ssrn && <span class="sep">&middot;</span>}
        {paper.ssrn && <a href={paper.ssrn} rel="noopener">SSRN</a>}
      </p>
    </article>
  ))}
</section>

</Site>
