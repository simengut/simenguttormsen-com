---
import Site from '../layouts/Site.astro';

interface EducationEntry {
  dates: string;
  degree: string;
  org: string;
  body?: string;
}

const education: EducationEntry[] = [
  {
    dates: '2025 — 2028',
    degree: 'PhD in Finance',
    org: 'Norwegian University of Life Sciences (NMBU) Business School · Ås, Norway',
    body: 'Research on implied-volatility surfaces, market microstructure, and investor learning about event risk.',
  },
  {
    dates: '2024 — 2025',
    degree: 'M.S. Economics & Computation',
    org: 'Duke University · Durham, NC · GPA 3.9 / 4.0',
  },
  {
    dates: '2019 — 2023',
    degree: 'B.S.E. Operations Research & Financial Engineering',
    org: 'Princeton University · magna cum laude · GPA 3.78 · Certificate in Finance',
  },
];

interface Result { year: string; description: string }

const seniorResults: Result[] = [
  { year: '2024', description: '15th, Olympic Games, Paris' },
  { year: '2026', description: 'Finalist, World Indoor Championships' },
  { year: '2022 · 2025', description: 'World Outdoor Championships (15th in 2022)' },
  { year: '2022 · 2024', description: 'European Outdoor Championships (13th in 2022, 16th in 2024)' },
];

const collegeResults: Result[] = [
  { year: '2025', description: 'NCAA Division I Indoor Pole Vault Champion' },
  { year: '2021 · 2024', description: 'Norwegian National Champion' },
  { year: '2019–2025', description: 'Four-time NCAA All-American · Ivy League and ACC record holder · three-time USTFCCCA All-Academic' },
];

const awards: string[] = [
  'NCAA Division I Indoor Pole Vault Champion (2025)',
  'Four-time NCAA All-American',
  'Ivy League and ACC record holder',
  'Three-time USTFCCCA All-Academic',
  '<em>magna cum laude</em>, Princeton University (2023)',
  'Princeton Certificate in Finance',
];
---
<Site title="Career" page="career"
  description="Career — academic, athletic, and professional background of Simen Guttormsen.">

<section class="page-header container">
  <h1>Career</h1>
  <p class="lede">Academic and athletic background, in parallel.</p>
</section>

<section class="container content-section">
  <h2>Education</h2>
  <ul class="timeline">
    {education.map((entry) => (
      <li>
        <span class="t-date">{entry.dates}</span>
        <div class="t-body">
          <h3>{entry.degree}</h3>
          <p class="t-org">{entry.org}</p>
          {entry.body && <p>{entry.body}</p>}
        </div>
      </li>
    ))}
  </ul>
</section>

<section class="container content-section">
  <h2>Athletics</h2>
  <p>I compete in the pole vault for Norway. Highlights below.</p>

  <h3 class="sub-h">Senior international</h3>
  <ul class="result-list">
    {seniorResults.map((r) => (
      <li><span class="r-year">{r.year}</span> {r.description}</li>
    ))}
  </ul>

  <h3 class="sub-h">National & collegiate</h3>
  <ul class="result-list">
    {collegeResults.map((r) => (
      <li><span class="r-year">{r.year}</span> {r.description}</li>
    ))}
  </ul>
</section>

<section class="container content-section">
  <h2>Teaching &amp; advising</h2>
  <article class="role">
    <h3>Master&rsquo;s thesis advisor</h3>
    <p class="paper-meta">NMBU Business School · 2025 — present</p>
    <p>Advise three Master&rsquo;s students/groups on quantitative-finance and econometrics theses — thesis design, methodology, and empirical implementation.</p>
  </article>
</section>

<section class="container content-section">
  <h2>Awards &amp; distinctions</h2>
  <ul class="award-list">
    {awards.map((a) => (
      <li set:html={a}></li>
    ))}
  </ul>
</section>

</Site>
