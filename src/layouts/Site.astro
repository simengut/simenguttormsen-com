---
import '../styles/main.css';
import { site, navItems, type SitePage } from '../data/site';

interface Props {
  /** Browser tab title (defaults to site name) */
  title?: string;
  /** Used to highlight the current entry in the nav */
  page?: SitePage | 'contact';
  /** Optional meta description override */
  description?: string;
}

const { title = site.name, page = 'home', description = site.description } = Astro.props;
const fullTitle = title === site.name ? site.name : `${title} — ${site.name}`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{fullTitle}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content={description}>
  <meta name="author" content={site.name}>
  <link rel="canonical" href={`${site.url}${Astro.url.pathname}`}>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%23111'/%3E%3Ctext x='50%25' y='56%25' dominant-baseline='middle' text-anchor='middle' font-family='-apple-system,Inter,sans-serif' font-weight='600' font-size='15' fill='%23fff'%3ESG%3C/text%3E%3C/svg%3E">
</head>
<body>

<header class="site-header">
  <div class="container header-row">
    <a href="/" class="site-name">{site.name}</a>
    <nav class="site-nav" aria-label="Primary">
      {navItems
        .filter((item) => import.meta.env.DEV || !item.devOnly)
        .map((item) => (
          <a href={item.href} class:list={[{ active: item.page === page }]}>{item.label}</a>
        ))}
    </nav>
  </div>
</header>

<main>
  <slot />
</main>

<footer class="site-footer">
  <div class="container footer-row">
    <p>&copy; 2026 {site.name}.</p>
    <p class="muted small">Updated May 2026.</p>
  </div>
</footer>

</body>
</html>
